PORT=3840
OPENAI_API_KEY=
# 文生图：dall-e-3 / gpt-image-1 等；有参考图时自动走 images/edits，建议 gpt-image-1 或 gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-1
# 可选：官方 https://api.openai.com/v1 或兼容网关
# OPENAI_BASE_URL=https://api.openai.com/v1

# 执行模式：
# - cloud = 纯云端（推荐）：可选 Webhook 返回参考图，再 OpenAI 出图
# - auto / server = 不等待本机 SU、无 Webhook，直接 AI
# - local = 本机 SketchUp 建模后上传 .skp
SU_EXECUTION=cloud

# 纯云端可选：自建 HTTPS 服务接收 multipart（字段 cad + jobId 等），JSON 返回 referenceImageBase64 或 referenceImageUrl
# 示例：将 vercel-cad-webhook 部署到 Vercel 后填：
# CLOUD_CAD_WEBHOOK_URL=https://<你的项目>.vercel.app/api/cad
# CLOUD_CAD_WEBHOOK_AUTH=Bearer your-token
# CLOUD_CAD_WEBHOOK_TIMEOUT_MS=120000
